# GNU GCC MinGW

#-- Generated during makefile build
*.d
*.o

#-- Generated UI test fixtures: too large for git, manufactured
#   deterministically by macos/ui-tests-xcode/run-tests.sh on first
#   invocation. Smaller fixtures stay checked in.
macos/ui-tests-xcode/fixtures/100MB.bin
macos/ui-tests-xcode/fixtures/17MB.bin
macos/ui-tests-xcode/fixtures/1.5GB.bin

#-- Distribution zip produced by `cmake --build`. The artifact to upload to a
#   GitHub Release, regenerated on every successful build, never checked in.
nppHexEditorPlugin-*.zip

