/* About / help dialog */
/* "N⁠o⁠t⁠e⁠p⁠a⁠d⁠+⁠+" includes U+2060 Word Joiners between every adjacent
   pair of characters so the product name is atomic against both word-
   wrap (which targets the '+' boundary) and macOS hyphenation (which
   was breaking it after "Note"). The body refers to the plugin's
   origin (a Notepad++ plugin on Windows ported to macOS), not the
   running host (which on Mac is Nextpad++). */
"about.body"                       = "Native macOS port of the N⁠o⁠t⁠e⁠p⁠a⁠d⁠+⁠+ HEX-Editor plugin. Provides an inline hex table with direct byte editing, selection, bookmarks, find/replace, compare, and view-mode switching.";
/* Plugin version line. %@ is the version string (e.g. "1.1.0"). */
"about.version"                    = "Version %@";
/* Diagnostic line in the About dialog — names the .strings file currently in
   use, so users (and the cascade XCTest) can see at a glance whether their
   translation loaded. Each shipped .strings file declares its own tag. */
"about.localeTag"                  = "Strings: en";

