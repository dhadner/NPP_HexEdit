/* Notepad++ HexEditor — Mexican Spanish (es-MX)
 *
 * Regional override file. Contains ONLY keys whose value differs from
 * Localizable.es.strings — the cascade in HexEditor.mm walks es-MX first,
 * then falls through to es, then to the embedded English defaults. Any
 * key the es-MX file omits cascades to es automatically; do NOT mirror
 * es here.
 *
 * Today the only divergence is the diagnostic locale tag in the About
 * dialog (so the cascade XCTest can see "Strings: es-MX" and verify
 * regional layering works). The base es.strings is already written in
 * neutral Spanish that suits Mexican readers — if a future string ever
 * uses a Peninsular-specific term ("ordenador", "fichero", etc.) the
 * Latin-American form belongs in es.strings and any Peninsular-specific
 * override goes in Localizable.es-ES.strings.
 */

/* About / help dialog — diagnostic locale tag */
"about.localeTag"                  = "Strings: es-MX";
