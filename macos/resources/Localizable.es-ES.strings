/* Notepad++ HexEditor — Peninsular Spanish (es-ES)
 *
 * Regional override file. Contains ONLY keys whose value differs from
 * Localizable.es.strings — the cascade in HexEditor.mm walks es-ES first,
 * then falls through to es, then to the embedded English defaults. Any
 * key the es-ES file omits cascades to es automatically; do NOT mirror
 * es here.
 *
 * Today the only divergence is the diagnostic locale tag in the About
 * dialog (so the cascade XCTest can see "Strings: es-ES" and verify
 * regional layering works). If a future string ever uses a
 * Peninsular-specific spelling or term ("ordenador" vs "computadora",
 * "fichero" vs "archivo"), add the Peninsular form here.
 */

/* About / help dialog — diagnostic locale tag */
"about.localeTag"                  = "Strings: es-ES";
