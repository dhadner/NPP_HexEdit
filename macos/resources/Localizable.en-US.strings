/* Notepad++ HexEditor — American English (en-US)
 *
 * Regional override file. en.strings is already American English (it is the
 * canonical translation source), so this file is intentionally near-empty —
 * its only purpose is to identify itself in the About dialog so the cascade
 * XCTest can prove that en-US loads ahead of en when AppleLanguages = (en-US).
 *
 * Add a key here ONLY if a future string needs an American-specific override
 * that diverges from the canonical en.strings (which would itself be unusual,
 * since en.strings is the American source of truth).
 */

/* About / help dialog — diagnostic locale tag */
"about.version"                    = "Version %@";
"about.localeTag"                  = "Strings: en-US";
